<svg viewBox="0 0 1200 675" xmlns="http://www.w3.org/2000/svg">
  <!-- Background gradient -->
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f5f5f5;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#ffffff;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <rect width="1200" height="675" fill="url(#bgGradient)"/>
  
  <!-- LEFT SIDE: Trust Signals -->
  <g>
    <!-- Title -->
    <text x="60" y="160" font-family="Inter, sans-serif" font-size="20" font-weight="700" fill="#000000">
      Trust Drivers
    </text>
    
    <!-- Bar 1: Why Recommended -->
    <rect x="80" y="200" width="280" height="45" fill="#f5f5f5" rx="8"/>
    <rect x="80" y="200" width="258" height="45" fill="#FF0000" rx="8" opacity="0.9"/>
    <text x="90" y="230" font-family="Inter, sans-serif" font-size="14" font-weight="600" fill="white">Why Recommended</text>
    <text x="350" y="230" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="#000000">92%</text>
    
    <!-- Bar 2: Control -->
    <rect x="80" y="260" width="280" height="45" fill="#f5f5f5" rx="8"/>
    <rect x="80" y="260" width="246" height="45" fill="#FF0000" rx="8" opacity="0.8"/>
    <text x="90" y="290" font-family="Inter, sans-serif" font-size="14" font-weight="600" fill="white">User Controls</text>
    <text x="350" y="290" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="#000000">88%</text>
    
    <!-- Bar 3: Privacy -->
    <rect x="80" y="320" width="280" height="45" fill="#f5f5f5" rx="8"/>
    <rect x="80" y="320" width="238" height="45" fill="#FF0000" rx="8" opacity="0.7"/>
    <text x="90" y="350" font-family="Inter, sans-serif" font-size="14" font-weight="600" fill="white">Privacy Info</text>
    <text x="350" y="350" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="#000000">85%</text>
    
    <!-- Bar 4: Accuracy -->
    <rect x="80" y="380" width="280" height="45" fill="#f5f5f5" rx="8"/>
    <rect x="80" y="380" width="179" height="45" fill="#FF0000" rx="8" opacity="0.4"/>
    <text x="90" y="410" font-family="Inter, sans-serif" font-size="14" font-weight="600" fill="white">Accuracy</text>
    <text x="350" y="410" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="#000000">64%</text>
  </g>
  
  <!-- CENTER: YOUTUBE LOGO -->
  <g>
    <!-- Play button circle -->
    <circle cx="600" cy="280" r="85" fill="#FF0000" opacity="0.95"/>
    
    <!-- Play triangle -->
    <polygon points="570,250 570,310 645,280" fill="white"/>
    
    <!-- YouTube text below -->
    <text x="600" y="410" font-family="Arial, sans-serif" font-size="36" font-weight="900" fill="#FF0000" text-anchor="middle">YouTube</text>
    <text x="600" y="440" font-family="Inter, sans-serif" font-size="14" font-weight="500" fill="#6b7280" text-anchor="middle">Recommendations</text>
  </g>
  
  <!-- RIGHT SIDE: User Archetypes -->
  <g>
    <!-- Title -->
    <text x="830" y="160" font-family="Inter, sans-serif" font-size="20" font-weight="700" fill="#000000">
      5 Archetypes
    </text>
    
    <!-- Archetype 1 -->
    <circle cx="880" cy="220" r="35" fill="#FF0000" opacity="0.95"/>
    <text x="880" y="235" font-family="Arial, sans-serif" font-size="20" font-weight="700" fill="white" text-anchor="middle">🔍</text>
    <text x="940" y="220" font-family="Inter, sans-serif" font-size="13" font-weight="600" fill="#000000">Discovery</text>
    <text x="940" y="238" font-family="Inter, sans-serif" font-size="11" fill="#6b7280">34% • High trust</text>
    
    <!-- Archetype 2 -->
    <circle cx="880" cy="295" r="35" fill="#FF0000" opacity="0.8"/>
    <text x="880" y="310" font-family="Arial, sans-serif" font-size="20" font-weight="700" fill="white" text-anchor="middle">🎯</text>
    <text x="940" y="295" font-family="Inter, sans-serif" font-size="13" font-weight="600" fill="#000000">Searchers</text>
    <text x="940" y="313" font-family="Inter, sans-serif" font-size="11" fill="#6b7280">28% • Low trust</text>
    
    <!-- Archetype 3 -->
    <circle cx="880" cy="370" r="35" fill="#FF0000" opacity="0.7"/>
    <text x="880" y="385" font-family="Arial, sans-serif" font-size="20" font-weight="700" fill="white" text-anchor="middle">📱</text>
    <text x="940" y="370" font-family="Inter, sans-serif" font-size="13" font-weight="600" fill="#000000">Habitual</text>
    <text x="940" y="388" font-family="Inter, sans-serif" font-size="11" fill="#6b7280">22% • Medium</text>
    
    <!-- Archetype 4 -->
    <circle cx="880" cy="445" r="35" fill="#FF0000" opacity="0.5"/>
    <text x="880" y="460" font-family="Arial, sans-serif" font-size="20" font-weight="700" fill="white" text-anchor="middle">🔒</text>
    <text x="940" y="445" font-family="Inter, sans-serif" font-size="13" font-weight="600" fill="#000000">Privacy</text>
    <text x="940" y="463" font-family="Inter, sans-serif" font-size="11" fill="#6b7280">11% • Very low</text>
    
    <!-- Archetype 5 -->
    <circle cx="880" cy="520" r="35" fill="#FF0000" opacity="0.8"/>
    <text x="880" y="535" font-family="Arial, sans-serif" font-size="20" font-weight="700" fill="white" text-anchor="middle">⚙️</text>
    <text x="940" y="520" font-family="Inter, sans-serif" font-size="13" font-weight="600" fill="#000000">Power Users</text>
    <text x="940" y="538" font-family="Inter, sans-serif" font-size="11" fill="#6b7280">5% • Medium-high</text>
  </g>
  
  <!-- Bottom stats -->
  <g>
    <!-- Stat 1 -->
    <rect x="60" y="600" width="210" height="55" fill="#f5f5f5" rx="12"/>
    <text x="85" y="625" font-family="Inter, sans-serif" font-size="28" font-weight="700" fill="#FF0000">68%</text>
    <text x="85" y="648" font-family="Inter, sans-serif" font-size="11" fill="#6b7280" font-weight="600">Current Trust</text>
    
    <!-- Arrow -->
    <text x="300" y="632" font-family="Inter, sans-serif" font-size="28" fill="#565D62" font-weight="700">→</text>
    
    <!-- Stat 2 -->
    <rect x="345" y="600" width="210" height="55" fill="#f5f5f5" rx="12"/>
    <text x="370" y="625" font-family="Inter, sans-serif" font-size="28" font-weight="700" fill="#FF0000">89%</text>
    <text x="370" y="648" font-family="Inter, sans-serif" font-size="11" fill="#6b7280" font-weight="600">Predicted Trust</text>
    
    <!-- Arrow -->
    <text x="600" y="632" font-family="Inter, sans-serif" font-size="28" fill="#565D62" font-weight="700">↑</text>
    
    <!-- Stat 3 -->
    <rect x="630" y="600" width="210" height="55" fill="#f5f5f5" rx="12"/>
    <text x="655" y="625" font-family="Inter, sans-serif" font-size="28" font-weight="700" fill="#FF0000">2.8x</text>
    <text x="655" y="648" font-family="Inter, sans-serif" font-size="11" fill="#6b7280" font-weight="600">Engagement ↑</text>
    
    <!-- Arrow -->
    <text x="885" y="632" font-family="Inter, sans-serif" font-size="28" fill="#565D62" font-weight="700">↓</text>
    
    <!-- Stat 4 -->
    <rect x="915" y="600" width="210" height="55" fill="#f5f5f5" rx="12"/>
    <text x="940" y="625" font-family="Inter, sans-serif" font-size="28" font-weight="700" fill="#FF0000">-61%</text>
    <text x="940" y="648" font-family="Inter, sans-serif" font-size="11" fill="#6b7280" font-weight="600">Privacy Concerns</text>
  </g>
</svg>
